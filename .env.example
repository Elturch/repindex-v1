# Dev-only auto-login for the Lovable preview environment.
#
# These variables are consumed by src/lib/devAutoLogin.ts and ONLY take effect
# when the app runs on a Lovable preview hostname (*.lovable.dev /
# *.lovableproject.com) or local development (localhost / 127.0.0.1).
# They are completely ignored on production hostnames (e.g. repindex.ai),
# so it is safe to leave them set in the project.
#
# In Lovable, set them in: Project Settings -> Environment Variables.
# (Both names must start with VITE_ so Vite exposes them to the client bundle.)

VITE_DEV_ADMIN_EMAIL=
VITE_DEV_ADMIN_PASSWORD=